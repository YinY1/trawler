# 依赖与构建产物
.venv/
node_modules/
vendor/
dist/
build/
*.egg-info/
trawler.egg-info/

# Python 缓存
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# 本地配置（运行时挂载，不进镜像）
config/config.toml
config/cookies.toml
config/subscriptions.toml
config/*.bak

# 本地数据（运行时挂载）
data/
downloads/
transcripts/
*.log

# 调试与临时
*_debug_tokens.json
debug_*.py

# 编辑器/IDE
.vscode/
.idea/
.DS_Store
Thumbs.db

# 工具索引（无需进镜像，徒增体积）
.codegraph/
.serena/
.superpowers/
.worktrees/

# Docker 自身（避免循环 COPY）
# 注意：docker/ 不能排除，Dockerfile 需要它
Dockerfile
docker-compose*.yml
.dockerignore

# 文档（运行时用不到）
docs/
README*.md
AGENTS.md
