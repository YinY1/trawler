# ═══════════════════════════════════════════════════════════════════
# Trawler 配置文件 — 复制为 config.toml 并根据需要修改
#
# 平台凭证（Cookie）请编辑 cookies.toml（参考 cookies.toml.example）
# 订阅列表请编辑 subscriptions.toml（参考 subscriptions.toml.example）
# ═══════════════════════════════════════════════════════════════════

# ── 通用设置 ─────────────────────────────────────────────────────
[general]
# 数据存储目录（相对路径基于项目根目录）
data_dir = "./data"

# ── 登录态自动续期 ─────────────────────────────────────────────
[auth.renewal]
# 距上次成功续期至少间隔多少小时才再次尝试
min_interval_hours = 24
# 距过期不到多少天时强制续期（即使 min_interval 未到）
force_before_days = 7
# 距上次刷新尝试超过此小时数也触发续期
max_interval_hours = 24
# 后台检查续期的时间间隔（小时）
check_interval_hours = 6

# ── 下载设置 ────────────────────────────────────────────────────
[download]
# 下载文件保存目录
dir = "./downloads"
# yt-dlp 画质偏好：worst / best / 具体格式
quality = "worst"
# yt-dlp 格式选择字符串
format = "bestaudio/worst"
# 最大同时下载数
max_concurrent = 3

# ── 转录设置（语音转文字）──────────────────────────────────────
[transcribe]
# FunASR 模型：base / medium / large
model = "base"
# 语言代码
language = "zh"
# 转录文本输出目录
output_dir = "./transcripts"
# 转录完成后是否删除原始音视频文件
delete_after_transcribe = true

# ── AI 分析设置 ────────────────────────────────────────────────
[analysis]
# 是否启用内容分析（摘要/标签等）
enabled = true
# 分析服务提供者：codebuddy / openai / 其他兼容接口
provider = "codebuddy"
# API 基础地址（留空使用 provider 默认地址）
api_base = ""
# API 密钥
api_key = ""
# 模型名称
model_name = ""

# ══════════════════════════════════════════════════════════════════
# B 站（Bilibili）配置
# ══════════════════════════════════════════════════════════════════

# 登录凭证请编辑 cookies.toml（[bilibili.auth]）
# 订阅列表请编辑 subscriptions.toml（[[bilibili.subscriptions]]）

[bilibili.monitor]
# 监控模式：rss（通过 RSSHub）或 dynamic（通过动态 API）
mode = "rss"
# 检查间隔（分钟）
interval_minutes = 3
# 是否同时监控动态（图文/短视频）
watch_dynamic = true
# 单次检查最多拉取的视频数
max_videos_per_check = 10
# RSSHub 实例列表（按优先级排序，自动 fallback）
rsshub_instances = [
    "https://rsshub.yfi.moe",
    "https://rsshub.liumingye.cn",
    "https://rss.shab.fun",
]

[bilibili.notification]
# 是否启用新视频通知
enabled = true
# Gotify 推送服务地址
gotify_url = ""
# Gotify 应用 Token
gotify_token = ""
# 通知优先级（1-10）
priority = 5

# ══════════════════════════════════════════════════════════════════
# 小红书（Xiaohongshu）配置
# ══════════════════════════════════════════════════════════════════

[xiaohongshu]
# 是否启用小红书监控（需要额外安装 xhs 依赖）
enabled = false

# 登录凭证请编辑 cookies.toml（[xiaohongshu.auth]）
# 订阅列表请编辑 subscriptions.toml（[[xiaohongshu.subscriptions]]）

[xiaohongshu.monitor]
# 监控模式：api / rss
mode = "api"
# 检查间隔（分钟）
interval_minutes = 10

[xiaohongshu.notification]
enabled = true
gotify_url = ""
gotify_token = ""
priority = 5

# ══════════════════════════════════════════════════════════════════
# 微博（Weibo）配置
# ══════════════════════════════════════════════════════════════════

[weibo]
# 是否启用微博监控
enabled = false

# 登录凭证请编辑 cookies.toml（[weibo.auth]）
# 订阅列表请编辑 subscriptions.toml（[[weibo.subscriptions]]）

[weibo.monitor]
# 监控模式：api / rss
mode = "api"
# 检查间隔（分钟）
interval_minutes = 10

[weibo.notification]
enabled = true
gotify_url = ""
gotify_token = ""
priority = 5
